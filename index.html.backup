const SPRITE_BASE = 'https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/';

// ===== BUILD SIDEBAR =====
function buildSidebar() {
  const list = document.getElementById('sidebar-list');
  TYPES.forEach((t, i) => {
    const a = document.createElement('a');
    a.href = `#section-${t.id}`;
    a.className = 'sidebar-item';
    a.dataset.type = t.id;
    a.setAttribute('aria-label', `${t.name} type — ${t.pokemon}`);
    a.innerHTML = `
      <div class="type-dot" style="--dot-color:${t.color};background:${t.color}"></div>
      <span>${t.pokemon}</span>
      <span class="type-badge-mini" style="background:${t.color}22;color:${t.color};border-color:${t.color}44">${t.name}</span>
    `;
    a.addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById(`section-${t.id}`).scrollIntoView({ behavior: 'smooth' });
    });
    list.appendChild(a);
  });
}

// ===== BUILD TYPE SECTIONS =====
function buildSections() {
  const container = document.getElementById('type-sections-container');
  TYPES.forEach((t, i) => {
    const strongList = t.strong.map(s => `<span class="eff-type-tag" style="color:${getTypeColor(s)};border-color:${getTypeColor(s)}44">${s}</span>`).join('');
    const weakList = t.weak.map(s => `<span class="eff-type-tag" style="color:${getTypeColor(s)};border-color:${getTypeColor(s)}44">${s}</span>`).join('');
    const resistList = t.resist.map(s => `<span class="eff-type-tag" style="color:${getTypeColor(s)};border-color:${getTypeColor(s)}44">${s}</span>`).join('') || '<span class="eff-type-tag">—</span>';
    const immuneList = t.immune.length ? `<div class="effectiveness-box"><div class="eff-label" style="color:#fbbf24">IMMUNE TO</div><div class="eff-types">${t.immune.map(s=>`<span class="eff-type-tag" style="color:${getTypeColor(s)};border-color:${getTypeColor(s)}44">${s}</span>`).join('')}</div></div>` : '';
    const typeBadgesHtml = t.types.map(tp => `<span class="type-badge" style="background:${getTypeColor(tp)}22;color:${getTypeColor(tp)};border-color:${getTypeColor(tp)}44">${tp}</span>`).join('');
    const isEven = i % 2 === 0;

    const section = document.createElement('section');
    section.id = `section-${t.id}`;
    section.className = `type-section`;
    section.dataset.type = t.id;
    section.dataset.color = t.color;
    const next = TYPES[i+1];
    const nextColor = next ? next.color : '#ffffff';
    const nextGlow = next ? next.glow : 'rgba(255,255,255,0.1)';
    section.style.cssText = `--type-color:${t.color};--type-glow:${t.glow};--type-shadow:${t.shadow};--next-type-color:${nextColor};--next-type-glow:${nextGlow}`;

    section.innerHTML = `
      <div class="type-bg ${t.bg}"></div>
      <div class="type-fx fx-${t.id}"></div>
      <div class="particle-layer" data-type="${t.id}"></div>
      ${isEven ? `
        <div class="type-content" style="font-family:${t.font}">
          <p class="type-label">#${String(i+1).padStart(2,'0')} · ${i === 0 ? 'First' : ['Second','Third','Fourth','Fifth','Sixth','Seventh','Eighth','Ninth','Tenth','Eleventh','Twelfth','Thirteenth','Fourteenth','Fifteenth','Sixteenth','Seventeenth','Eighteenth'][i-1]} Type</p>
          <h2 class="type-name" style="font-family:${t.font};font-weight:${t.fontWeight}">${t.name}</h2>
          <p class="pokemon-name">${t.pokemon}</p>
          <div class="type-badges">${typeBadgesHtml}</div>
          <p class="type-description">${t.whyBest}</p>
          <p class="type-description" style="opacity:0.6;font-size:13px;margin-bottom:20px">${t.typeRole}</p>
          <div class="pokedex-entry">
            <div class="label">◆ POKÉDEX</div>
            <p>${t.dex}</p>
          </div>
          <div class="type-effectiveness">
            <div class="effectiveness-box"><div class="eff-label strong">STRONG VS</div><div class="eff-types">${strongList || '<span class="eff-type-tag">—</span>'}</div></div>
            <div class="effectiveness-box"><div class="eff-label weak">WEAK TO</div><div class="eff-types">${weakList}</div></div>
            <div class="effectiveness-box"><div class="eff-label resist">RESISTS</div><div class="eff-types">${resistList}</div></div>
            ${immuneList}
          </div>
        </div>
        <div class="type-image-side">
          <div class="type-number">${String(i+1).padStart(2,'0')}</div>
          <img class="pokemon-artwork" src="${SPRITE_BASE}${t.pokemonId}.png" alt="${t.pokemon} official artwork" loading="lazy">
        </div>
      ` : `
        <div class="type-image-side">
          <div class="type-number">${String(i+1).padStart(2,'0')}</div>
          <img class="pokemon-artwork" src="${SPRITE_BASE}${t.pokemonId}.png" alt="${t.pokemon} official artwork" loading="lazy">
        </div>
        <div class="type-content" style="font-family:${t.font};padding-left:60px">
          <p class="type-label">#${String(i+1).padStart(2,'0')} · Type</p>
          <h2 class="type-name" style="font-family:${t.font};font-weight:${t.fontWeight}">${t.name}</h2>
          <p class="pokemon-name">${t.pokemon}</p>
          <div class="type-badges">${typeBadgesHtml}</div>
          <p class="type-description">${t.whyBest}</p>
          <p class="type-description" style="opacity:0.6;font-size:13px;margin-bottom:20px">${t.typeRole}</p>
          <div class="pokedex-entry">
            <div class="label">◆ POKÉDEX</div>
            <p>${t.dex}</p>
          </div>
          <div class="type-effectiveness">
            <div class="effectiveness-box"><div class="eff-label strong">STRONG VS</div><div class="eff-types">${strongList || '<span class="eff-type-tag">—</span>'}</div></div>
            <div class="effectiveness-box"><div class="eff-label weak">WEAK TO</div><div class="eff-types">${weakList}</div></div>
            <div class="effectiveness-box"><div class="eff-label resist">RESISTS</div><div class="eff-types">${resistList}</div></div>
            ${immuneList}
          </div>
        </div>
      `}
      <div class="section-divider"></div>
    `;
    container.appendChild(section);
  });
}

function getTypeColor(type) {
  const colors = {
    Normal:'#A8A77A', Fire:'#EE8130', Water:'#6390F0', Grass:'#7AC74C',
    Electric:'#F7D02C', Ice:'#96D9D6', Fighting:'#C22E28', Poison:'#A33EA1',
    Ground:'#E2BF65', Flying:'#A98FF3', Psychic:'#F95587', Bug:'#A6B91A',
    Rock:'#B6A136', Ghost:'#735797', Dragon:'#6F35FC', Dark:'#705746',
    Steel:'#B7B7CE', Fairy:'#D685AD'
  };
  return colors[type] || '#ffffff';
}

// ===== LANDING ORBS =====
function buildOrbs() {
  const container = document.getElementById('landing-orbs');
  const outro = document.getElementById('outro-orbs');
  TYPES.forEach((t, i) => {
    const orb = document.createElement('div');
    orb.className = 'type-orb';
    orb.style.cssText = `background:${t.color};box-shadow:0 0 12px ${t.glow};animation-delay:${i * 0.1}s;animation-duration:${3 + i * 0.15}s`;
    orb.title = t.name;
    container.appendChild(orb);

    const outroOrb = orb.cloneNode();
    outroOrb.style.cssText = `background:${t.color};box-shadow:0 0 8px ${t.glow};width:12px;height:12px;animation-delay:${i*0.15}s`;
    outro.appendChild(outroOrb);
  });
}

// ===== STARS CANVAS =====
function initStars() {
  const canvas = document.getElementById('stars-canvas');
  const ctx = canvas.getContext('2d');
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
  const stars = Array.from({length: 200}, () => ({
    x: Math.random() * canvas.width,
    y: Math.random() * canvas.height,
    r: Math.random() * 1.5,
    o: Math.random(),
    speed: Math.random() * 0.005 + 0.002,
  }));
  function drawStars() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    stars.forEach(s => {
      s.o += s.speed;
      ctx.globalAlpha = (Math.sin(s.o) + 1) / 2 * 0.8 + 0.1;
      ctx.fillStyle = '#fff';
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fill();
    });
    requestAnimationFrame(drawStars);
  }
  drawStars();
  window.addEventListener('resize', () => {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  });
}

// ===== CUSTOM CURSOR =====
const cursorCanvas = document.getElementById('cursor-canvas');
const cursorCtx = cursorCanvas.getContext('2d');
const cursorDot = document.getElementById('cursor-dot');
const cursorRing = document.getElementById('cursor-ring');
cursorCanvas.width = window.innerWidth;
cursorCanvas.height = window.innerHeight;

let mouse = { x: -200, y: -200 };
let currentTypeData = null;
let particles = [];
let cursorDotPos = { x: -200, y: -200 };
let ringPos = { x: -200, y: -200 };

document.addEventListener('mousemove', (e) => {
  mouse.x = e.clientX;
  mouse.y = e.clientY;
  cursorDot.style.left = e.clientX + 'px';
  cursorDot.style.top = e.clientY + 'px';
  ringPos.x += (e.clientX - ringPos.x) * 0.12;
  ringPos.y += (e.clientY - ringPos.y) * 0.12;
  cursorRing.style.left = ringPos.x + 'px';
  cursorRing.style.top = ringPos.y + 'px';
  if (currentTypeData) spawnCursorParticles(e.clientX, e.clientY);
});

function spawnCursorParticles(x, y) {
  const colors = currentTypeData.cursorColors;
  for (let i = 0; i < 2; i++) {
    const angle = Math.random() * Math.PI * 2;
    const speed = Math.random() * 2 + 0.5;
    particles.push({
      x, y,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed - 1,
      life: 1,
      decay: Math.random() * 0.04 + 0.02,
      size: Math.random() * 4 + 2,
      color: colors[Math.floor(Math.random() * colors.length)],
    });
  }
}

function animateCursor() {
  cursorCtx.clearRect(0, 0, cursorCanvas.width, cursorCanvas.height);
  particles = particles.filter(p => p.life > 0);
  particles.forEach(p => {
    p.x += p.vx;
    p.y += p.vy;
    p.vy += 0.05;
    p.vx *= 0.96;
    p.life -= p.decay;
    cursorCtx.globalAlpha = p.life * 0.8;
    cursorCtx.fillStyle = p.color;
    cursorCtx.shadowColor = p.color;
    cursorCtx.shadowBlur = 6;
    cursorCtx.beginPath();
    cursorCtx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
    cursorCtx.fill();
  });
  cursorCtx.shadowBlur = 0;
  cursorCtx.globalAlpha = 1;
  requestAnimationFrame(animateCursor);
}
animateCursor();

function updateCursorForType(typeData) {
  if (!typeData) return;
  currentTypeData = typeData;
  const color = typeData.color;
  cursorDot.style.background = color;
  cursorDot.style.boxShadow = `0 0 12px ${typeData.glow}, 0 0 4px ${color}`;
  cursorRing.style.borderColor = color + '80';
  document.documentElement.style.setProperty('--current-color', color);
}

window.addEventListener('resize', () => {
  cursorCanvas.width = window.innerWidth;
  cursorCanvas.height = window.innerHeight;
});

// ===== FLOATING PARTICLES PER SECTION =====
// Per-type particle config: motion, shape, count, size range, color, glow
const PARTICLE_CONFIGS = {
  normal:   { motion: 'drift',    count: 18, size: [2,4], color: '#d4c896', glow: true,  dur: [10,18] },
  fire:     { motion: 'rise',     count: 32, size: [2,5], color: '#ff8a3a', glow: true,  dur: [5,10] },
  water:    { motion: 'bubble',   count: 26, size: [3,8], color: '#7ab0ff', glow: true,  shape: 'ring', dur: [7,14] },
  grass:    { motion: 'fall',     count: 20, size: [6,11], color: '#8fd858', shape: 'leaf', dur: [8,16] },
  electric: { motion: 'spark',    count: 28, size: [1,3], color: '#ffef6a', glow: true,  dur: [1.2,2.5] },
  ice:      { motion: 'fall',     count: 32, size: [2,5], color: '#dbeff7', glow: true,  dur: [8,15] },
  fighting: { motion: 'spark',    count: 16, size: [2,4], color: '#ff6a62', glow: true,  dur: [1.5,3] },
  poison:   { motion: 'bubble',   count: 20, size: [3,7], color: '#d06ad0', glow: true,  dur: [7,13] },
  ground:   { motion: 'drift',    count: 22, size: [1,3], color: '#e2bf65', glow: false, dur: [6,12] },
  flying:   { motion: 'streak',   count: 14, size: [1,2], color: '#c7b7ff', glow: false, dur: [3,6] },
  psychic:  { motion: 'twinkle',  count: 20, size: [2,4], color: '#ff9fc3', glow: true,  shape: 'star', dur: [2,4] },
  bug:      { motion: 'twinkle',  count: 22, size: [2,5], color: '#d4e260', glow: true,  dur: [1.5,3.5] },
  rock:     { motion: 'drift',    count: 22, size: [1,3], color: '#d4bd56', glow: false, dur: [5,10] },
  ghost:    { motion: 'rise',     count: 16, size: [3,7], color: '#b489d9', glow: true,  dur: [5,11] },
  dragon:   { motion: 'rise',     count: 18, size: [2,4], color: '#a76aff', glow: true,  dur: [6,12] },
  dark:     { motion: 'drift',    count: 14, size: [2,4], color: '#b8a090', glow: false, dur: [8,14] },
  steel:    { motion: 'spark',    count: 22, size: [1,2], color: '#d6d6ea', glow: true,  dur: [1.8,3.5] },
  fairy:    { motion: 'twinkle',  count: 26, size: [2,5], color: '#ffb3d3', glow: true,  shape: 'star', dur: [1.8,4] }
};

function initSectionParticles() {
  document.querySelectorAll('.particle-layer').forEach(layer => {
    const typeId = layer.dataset.type;
    const cfg = PARTICLE_CONFIGS[typeId] || { motion: 'drift', count: 10, size: [2,4], color: '#ffffff', glow: true, dur: [8,14] };
    layer.innerHTML = '';
    for (let i = 0; i < cfg.count; i++) {
      const p = document.createElement('div');
      const size = cfg.size[0] + Math.random() * (cfg.size[1] - cfg.size[0]);
      const duration = cfg.dur[0] + Math.random() * (cfg.dur[1] - cfg.dur[0]);
      const delay = -Math.random() * duration;
      const left = Math.random() * 100;
      const top = Math.random() * 100;

      let cls = 'particle';
      // pick motion class
      if (cfg.motion === 'rise')    cls += ' p-rise';
      if (cfg.motion === 'bubble')  cls += ' p-bubble';
      if (cfg.motion === 'fall')    cls += ' p-fall';
      if (cfg.motion === 'drift')   cls += ' p-drift';
      if (cfg.motion === 'spark')   cls += ' p-spark';
      if (cfg.motion === 'streak')  cls += ' p-streak-m p-streak';
      if (cfg.motion === 'twinkle') cls += ' p-twinkle';
      // shape modifiers
      if (cfg.shape === 'leaf') cls += ' p-leaf';
      if (cfg.shape === 'ring') cls += ' p-ring';
      if (cfg.shape === 'star') cls += ' p-star';
      p.className = cls;

      const glow = cfg.glow ? `0 0 ${size*3}px ${cfg.color}` : 'none';
      // streak uses horizontal stretch
      let widthStyle = `${size}px`, heightStyle = `${size}px`;
      if (cfg.motion === 'streak') { widthStyle = `${40 + Math.random()*40}px`; heightStyle = '1px'; }

      p.style.cssText = `
        width:${widthStyle}; height:${heightStyle};
        left:${left}%; top:${top}%;
        background:${cfg.color};
        color:${cfg.color};
        box-shadow:${glow};
        animation-duration:${duration}s;
        animation-delay:${delay}s;
      `;
      layer.appendChild(p);
    }
  });
}

// Scroll-linked parallax on type backgrounds for smooth transitions between sections
function initParallax() {
  const bgs = Array.from(document.querySelectorAll('.type-bg'));
  let scheduled = false;
  const update = () => {
    scheduled = false;
    const vh = innerHeight;
    bgs.forEach(bg => {
      const section = bg.parentElement;
      const rect = section.getBoundingClientRect();
      if (rect.bottom < -200 || rect.top > vh + 200) return;
      const progress = (rect.top - vh) / (rect.height + vh) + 0.5;
      const ty = progress * 60;
      bg.style.transform = `translate3d(0, ${ty}px, 0) scale(1.08)`;
    });
  };
  const schedule = () => {
    if (scheduled) return;
    scheduled = true;
    (typeof requestAnimationFrame === 'function' ? requestAnimationFrame : (cb) => setTimeout(cb, 16))(update);
  };
  window.addEventListener('scroll', schedule, { passive: true });
  update();
}

// ===== SCROLL-BASED VISIBILITY (replaces IntersectionObserver for preview compat) =====
function initObserver() {
  const sections = Array.from(document.querySelectorAll('.type-section'));
  const landing = document.getElementById('landing');
  const sidebarItems = document.querySelectorAll('.sidebar-item');
  let activeTypeId = null;
  let scheduled = false;

  const update = () => {
    scheduled = false;
    const vh = innerHeight;
    const vhCenter = vh / 2;

    // Landing check — reset cursor when landing is mostly visible
    const landingRect = landing.getBoundingClientRect();
    const landingVisible = landingRect.bottom > vhCenter && landingRect.top < vhCenter;
    if (landingVisible && activeTypeId !== null) {
      cursorDot.style.background = '#fff';
      cursorDot.style.boxShadow = 'none';
      cursorRing.style.borderColor = 'rgba(255,255,255,0.5)';
      currentTypeData = null;
      document.documentElement.style.setProperty('--current-color', '#fff');
      sidebarItems.forEach(item => item.classList.remove('active'));
      activeTypeId = null;
    }

    // Find the section whose center is closest to the viewport center
    let bestId = null;
    let bestDist = Infinity;
    sections.forEach(s => {
      const rect = s.getBoundingClientRect();
      const nearViewport = rect.bottom > -200 && rect.top < vh + 200;
      s.classList.toggle('active-fx', nearViewport);
      const fullyVisible = rect.top < vh * 0.7 && rect.bottom > vh * 0.3;
      s.classList.toggle('visible', fullyVisible || rect.top < vh * 0.5);
      const center = rect.top + rect.height / 2;
      const dist = Math.abs(center - vhCenter);
      if (rect.bottom > 0 && rect.top < vh && dist < bestDist) {
        bestDist = dist;
        bestId = s.dataset.type;
      }
    });

    if (bestId && bestId !== activeTypeId && !landingVisible) {
      activeTypeId = bestId;
      const typeData = TYPES.find(t => t.id === bestId);
      updateCursorForType(typeData);
      sidebarItems.forEach(item => {
        item.classList.toggle('active', item.dataset.type === bestId);
      });
    }
  };

  const schedule = () => {
    if (scheduled) return;
    scheduled = true;
    // Use setTimeout fallback in case rAF is throttled (preview/background tab)
    (typeof requestAnimationFrame === 'function' ? requestAnimationFrame : (cb) => setTimeout(cb, 16))(update);
  };
  window.addEventListener('scroll', schedule, { passive: true });
  window.addEventListener('resize', schedule, { passive: true });
  // Run now and after layout settles
  update();
  setTimeout(update, 100);
  setTimeout(update, 400);
}

// ===== INIT =====
document.addEventListener('DOMContentLoaded', () => {
  buildSidebar();
  buildSections();
  buildOrbs();
  initStars();
  initSectionParticles();
  initParallax();
  initObserver();
});
</script>
</body>
</html>
